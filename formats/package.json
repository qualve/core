{
	"name": "@qualve/formats",
	"version": "0.0.1",
	"description": "Format plugins for Qualve — CSV, TSV, and more.",
	"type": "module",
	"engines": {
		"node": ">=23"
	},
	"main": "src/index.js",
	"workspaces": [
		"csv",
		"yaml"
	],
	"exports": {
		".": "./src/index.js",
		"./csv": "./src/csv.js",
		"./yaml": "./src/yaml.js"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/qualve/formats.git"
	},
	"author": "Lea Verou",
	"contributors": [
		"Dmitry Sharabin"
	],
	"scripts": {
		"test": "npx htest test",
		"release": "npm whoami >/dev/null 2>&1 || npm login && release-it"
	},
	"peerDependencies": {
		"qualve": "*"
	},
	"devDependencies": {
		"htest.dev": "^0.0.24",
		"prettier": "^3.8.1",
		"prettier-plugin-brace-style": "^0.10.0",
		"prettier-plugin-merge": "^0.10.0",
		"prettier-plugin-space-before-function-paren": "^0.1.0",
		"release-it": "^20.0.0"
	},
	"dependencies": {
		"@qualve/csv": "*",
		"@qualve/yaml": "*"
	}
}
